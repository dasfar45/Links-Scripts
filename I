        if (!active) {
            document.querySelectorAll('.custom-chess-bg-video').forEach(el => el.style.display = 'none');
            isVideoEnsuring = false;
            return;
        }

        let activeVideo = cachedVideoData;
        if (!activeVideo) {
            isVideoEnsuring = false;
            return;
        }

        if (activeVideo.startsWith("LOCAL_DB_VIDEO")) {
            const b64 = await getLocalVideoURL(activeVideo);
            if (!b64) {
                isVideoEnsuring = false;
                return;
            }
            activeVideo = b64;
        } else {
            activeVideo = fixGitHubUrl(activeVideo);
        }

