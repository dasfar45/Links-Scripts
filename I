    const getVideoHash = (str) => {
        if (!str) return "0";
        let hash = 0;
        for (let i = 0; i < str.length && i < 1000; i++) {
            hash = (hash << 5) - hash + str.charCodeAt(i);
            hash |= 0;
        }
        return hash + "_" + str.length;
    };

